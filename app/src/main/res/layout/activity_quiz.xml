<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F5F7FA"
    tools:context=".QuizActivity">

    <TextView
        android:id="@+id/tvWelcomeQuiz"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hello! 載入中..."
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#1A2530"
        android:layout_marginTop="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tvQuestionCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="問題：1 / 10"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#34495E" />

        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏱️ 時間：0 秒"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#E74C3C" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutQuestionCard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3"
        android:background="@android:drawable/dialog_holo_light_frame"
        android:backgroundTint="#FFFFFF"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:layout_marginBottom="24dp">

        <TextView
            android:id="@+id/tvQuizQuestion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="題目載入中，請稍候..."
            android:textSize="22sp"
            android:textColor="#2C3E50"
            android:gravity="center"
            android:lineSpacingMultiplier="1.3" />
    </LinearLayout>

    <EditText
        android:id="@+id/etQuizAnswer"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:hint="請在這裡輸入答案"
        android:gravity="center"
        android:textSize="22sp"
        android:inputType="number"
        android:background="@android:drawable/editbox_background_normal"
        android:layout_marginBottom="20dp" />

    <Button
        android:id="@+id/btnNextQuestion"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="#3498DB"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text="下一題 🚀"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnPauseResume"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:backgroundTint="#E67E22"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text="⏸️ 暫停休息一下"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold" />

</LinearLayout>